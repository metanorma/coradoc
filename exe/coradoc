#!/usr/bin/env ruby
# frozen_string_literal: true

# Coradoc CLI executable
#
# Provides command-line access to Coradoc document conversion functionality.
#
# @example Convert AsciiDoc to HTML
#   coradoc convert document.adoc -o output.html
#
# @example Convert Markdown to HTML
#   coradoc convert document.md -o output.html --theme modern
#
# @example Show help
#   coradoc help

lib_path = File.expand_path('../lib', __dir__)
$LOAD_PATH.unshift(lib_path) unless $LOAD_PATH.include?(lib_path)

require 'coradoc'
require 'coradoc/cli'

# Load available format gems
require 'coradoc/html'
require 'coradoc/markdown'

begin
  require 'coradoc/docx'
rescue LoadError
  # coradoc-docx gem not installed; DOCX support unavailable
end

Coradoc::CLI.start(ARGV)
