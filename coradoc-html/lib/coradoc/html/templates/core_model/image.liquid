{% if element.inline? %}
<img src="{{ element.src }}"{% if element.alt %} alt="{{ element.alt }}"{% endif %}{% if element.width %} width="{{ element.width }}"{% endif %}{% if element.height %} height="{{ element.height }}"{% endif %}>
{% else %}
<figure{% if element.id %} id="{{ element.id }}"{% endif %}>
<img src="{{ element.src }}"{% if element.alt %} alt="{{ element.alt }}"{% endif %}{% if element.width %} width="{{ element.width }}"{% endif %}{% if element.height %} height="{{ element.height }}"{% endif %}>
{% if element.caption %}
<figcaption>{{ element.caption }}</figcaption>
{% endif %}
</figure>
{% endif %}
