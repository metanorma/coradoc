{%- comment -%}
Image template

Handles block and inline images with captions.
{%- endcomment -%}

{%- if inline -%}
  <img src="{{ src }}" alt="{{ alt }}" class="inline-image"
  {% elsif %}
    <figure id="{{ id }}" class="image{% if caption %}<figcaption>{{ caption }}</figcaption>{% endif %}
  </figure>
{%- else -%}
  <img src="{{ src }}" alt="{{ alt }}" class="block-image"
  {% if width %} width="{{ width }}"{% endif %}
  {% if height %} height="{{ height }}"{% endif %}
</img>
{%- endif -%}
