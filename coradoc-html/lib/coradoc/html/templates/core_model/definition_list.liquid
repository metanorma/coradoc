<dl{% if element.id %} id="{{ element.id }}"{% endif %}{% if element.title %} title="{{ element.title }}"{% endif %}>
{% for item in element.items %}
<dt{% if item.term_id %} id="{{ item.term_id }}"{% endif %}>{{ item.term }}</dt>
{% for defn in item.definitions %}
<dd>{{ defn | render_element }}</dd>
{% endfor %}
{% if item.nested %}
<dd>{{ item.nested | render_element }}</dd>
{% endif %}
{% endfor %}
</dl>
